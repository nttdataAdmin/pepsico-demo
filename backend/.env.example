# Copy to .env and fill in. Do not commit .env.

# Optional: path to workbook (default: repo root super_excel.xlsx)
# SUPER_EXCEL_PATH=C:\path\to\super_excel.xlsx

# Azure Document Intelligence — optional OCR for form classification
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_DOC_INTELLIGENCE_KEY=
# Set to true to call Read API when filename does not indicate outcome
AZURE_DOC_INTELLIGENCE_USE_OCR=false

# When OCR is off and filename is neutral: go | no_go
FORM_CLASSIFY_DEFAULT=go

# Microsoft Graph — send maintenance work-order notifications (MSAL client credentials)
# App registration: Application permission Mail.Send; admin consent required.
# GRAPH_MAILBOX_UPN = mailbox that sends (must match a licensed user / shared mailbox policy in your tenant).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX_UPN=
# Default To: address when the UI does not override (e.g. operations inbox)
GRAPH_NOTIFY_DEFAULT_TO=

# --- OR use SMTP instead of Graph (no Entra app required) ---
# Office 365 example: SMTP_HOST=smtp.office365.com  SMTP_PORT=587  SMTP_USE_TLS=true
# SMTP_USER / SMTP_FROM = your mailbox; SMTP_PASSWORD = app password or account password per org policy
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
